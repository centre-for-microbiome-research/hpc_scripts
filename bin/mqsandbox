#!/bin/bash
# mqsandbox - run an arbitrary command inside the same restricted
# Apptainer/Singularity container that mqyolo uses for interactive AI sessions.
#
# It enforces the same filesystem constraints as mqyolo:
#   - the working directory:  read-write
#   - /tmp, /var/tmp:         read-write
#   - HPC data mounts, /etc:  read-only
#   - everything else:        not visible (--contain)
#   - $HOME:                  ephemeral, dotfiles symlinked from the real home
#
# This is what `mqsub --sandbox` wraps each submitted job in, so jobs run on the
# compute nodes under the very same constraints as the interactive session that
# submitted them.
#
# Usage:
#   mqsandbox [--cwd DIR] [--rw-paths PATH...] [--ro-paths PATH...] [--sif PATH] [--debug] -- command [args...]
#
# Environment variables:
#   AI_TOOL_SIF   Override path to the .sif image (default: ../singularity/ai_tool.sif)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck source=_sandbox_common.bash
source "${SCRIPT_DIR}/_sandbox_common.bash"

SIF="${AI_TOOL_SIF:-${SCRIPT_DIR}/../singularity/ai_tool.sif}"
CWD=""
DEBUG=0
RW_PATHS=()
RO_PATHS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --cwd)      CWD="$2"; shift 2 ;;
        --sif)      SIF="$2"; shift 2 ;;
        --debug)    DEBUG=1; shift ;;
        --rw-paths)
            shift
            while [[ $# -gt 0 && "$1" != --* && "$1" != "--" ]]; do
                RW_PATHS+=("$1"); shift
            done
            ;;
        --ro-paths)
            shift
            while [[ $# -gt 0 && "$1" != --* && "$1" != "--" ]]; do
                RO_PATHS+=("$1"); shift
            done
            ;;
        --)         shift; break ;;
        -h|--help)
            sed -n '2,25p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
            exit 0 ;;
        *)          break ;;
    esac
done

if [[ $# -eq 0 ]]; then
    echo "mqsandbox: no command given (did you forget '--'?)" >&2
    exit 2
fi

sandbox_detect_runtime
sandbox_require_sif "$SIF"

[[ -z "$CWD" ]] && CWD="$(pwd)"
CWD="$(realpath "$CWD")"

BIND_ARGS=()
ENV_ARGS=()

sandbox_make_home
trap 'rm -rf "$CONTAINER_HOME"' EXIT
# Default per-user scratch binds (when present), same as mqyolo: expose
# /scratch/microbiome/$USER/non_sensitive read-only with its `scratch` subdir
# read-write. Harmless if the broker already forwarded them (deduped below).
sandbox_add_default_scratch_paths
sandbox_build_binds "$CWD" "${RW_PATHS[@]+"${RW_PATHS[@]}"}" -- "${RO_PATHS[@]+"${RO_PATHS[@]}"}"
sandbox_home_dotfiles
# Forward terminal-rendering vars and the pixi/rattler cache location (so jobs
# that run pixi reuse the rw-bound cache); jobs should not inherit API keys.
sandbox_build_env PIXI_CACHE_DIR RATTLER_CACHE_DIR TERM COLORTERM NO_COLOR

# Drop duplicate-destination binds so apptainer doesn't warn "destination is
# already in the mount point list" (last bind per dest wins; see
# sandbox_dedupe_binds). Jobs inherit the same --ro-paths that collide in mqyolo.
sandbox_dedupe_binds

if [[ "$DEBUG" -eq 1 ]]; then
    echo "mqsandbox: exec command:" >&2
    printf '  %q' "$RUNTIME" exec --contain \
        "${BIND_ARGS[@]}" "${ENV_ARGS[@]}" \
        --pwd "${CWD}" "${SIF}" \
        bash -c '[[ -f ~/.bashrc ]] && source ~/.bashrc 2>/dev/null; exec "$@"' _ "$@" >&2
    echo >&2
fi

# Run as a child (not exec) so the EXIT trap fires and the temp home is removed
# — important on compute nodes where it would otherwise leak under /tmp.
"$RUNTIME" exec \
    --contain \
    "${BIND_ARGS[@]}" \
    "${ENV_ARGS[@]}" \
    --pwd "${CWD}" \
    "${SIF}" \
    bash -c '[[ -f ~/.bashrc ]] && source ~/.bashrc 2>/dev/null; exec "$@"' _ "$@"
exit $?
