#!/bin/bash
# mqyolo - Run claude, codex, or copilot inside a restricted Apptainer/Singularity container.
#
# Permissions inside the container:
#   - Current directory: fully read/write
#   - /tmp, /var/tmp:    read/write
#   - Everything else:   read-only (Unix permissions still apply)
#   - $HOME:             isolated ephemeral directory, not your real home
#
# Usage:
#   mqyolo [claude|codex|copilot] [args...]
#
# Environment variables:
#   ANTHROPIC_API_KEY   Required for claude
#   OPENAI_API_KEY      Required for codex
#   GITHUB_TOKEN        Required for copilot
#   AI_TOOL_SIF         Override path to .sif file (default: same dir as this script)
#
# The filesystem-sandbox construction is shared with mqsandbox via
# _sandbox_common.bash so that jobs submitted from inside the container (see the
# "mqsub from inside the container" section below) run under the same constraints.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck source=_sandbox_common.bash
source "${SCRIPT_DIR}/_sandbox_common.bash"

SIF="${AI_TOOL_SIF:-${SCRIPT_DIR}/../singularity/ai_tool.sif}"

# JSON config listing /work folders flagged "not sensitive" in the CMR
# work-folders sheet. Found via a path relative to this script so it ships with
# the repo (and the deployed copy). Read fresh on every launch (see below);
# regenerate it from the sheet with `pixi run update-non-sensitive-folders`.
NON_SENSITIVE_FOLDERS_FILE="${SCRIPT_DIR}/../mqyolo-non-sensitive-folders.json"

# Print one non-sensitive folder per line from the JSON config (nothing if the
# file is absent or unparseable, so a missing/broken config is non-fatal). Uses
# python3, falling back to jq, then a minimal grep for quoted absolute paths.
_mqyolo_non_sensitive_folders() {
    local file="$1"
    [[ -f "$file" ]] || return 0
    if command -v python3 &>/dev/null; then
        python3 - "$file" <<'PY' 2>/dev/null
import json, sys
try:
    with open(sys.argv[1]) as f:
        data = json.load(f)
    for p in data.get("non_sensitive_folders", []):
        if isinstance(p, str) and p.strip():
            print(p.strip())
except Exception:
    pass
PY
    elif command -v jq &>/dev/null; then
        jq -r '.non_sensitive_folders[]? // empty' "$file" 2>/dev/null
    else
        # Last resort: the only quoted "/..." strings in the file are the folders.
        grep -oE '"/[^"]*"' "$file" 2>/dev/null | tr -d '"'
    fi
}

# Trees mqyolo may be launched from. The working directory is bound read-WRITE
# into the sandbox, so launching from an arbitrary location would expose (and make
# writable) unrelated data to the AI. Restrict CWD to a small set of expected
# areas to limit accidental leakage. Each entry is matched against the resolved
# CWD as both the literal path and its realpath, so the canonical aliases are
# covered too (/work/microbiome -> /mnt/hpccs01/..., /scratch -> /mnt/weka/...).
_mqyolo_allowed_launch_roots() {
    printf '%s\n' \
        /work/microbiome \
        "${HOME:-}" \
        "/scratch/microbiome/${USER:-}" \
        /tmp
}

# True (0) if the resolved working directory CWD_REAL is at or under one of the
# allowed launch roots; false (1) otherwise.
_mqyolo_allowed_cwd() {
    local cwd_real="$1" root root_real
    while IFS= read -r root; do
        [[ -n "$root" && "$root" != "/scratch/microbiome/" ]] || continue
        for root_real in "$root" "$(realpath -m "$root" 2>/dev/null)"; do
            [[ -n "$root_real" ]] || continue
            [[ "$cwd_real" == "$root_real" || "$cwd_real" == "$root_real"/* ]] && return 0
        done
    done < <(_mqyolo_allowed_launch_roots)
    return 1
}

# Convert a PBS mem string (e.g. 96gb, 98304mb, 2tb) to whole GB, or "" if unknown.
_mqyolo_mem_to_gb() {
    local v="${1,,}" num
    num="${v//[^0-9]/}"
    [[ -n "$num" ]] || { echo ""; return; }
    case "$v" in
        *tb) echo $(( num * 1024 )) ;;
        *gb) echo "$num" ;;
        *mb) echo $(( num / 1024 )) ;;
        *kb) echo $(( num / 1024 / 1024 )) ;;
        *)   echo "" ;;
    esac
}

# Detect where mqyolo is running so the guidance can adapt: a shared login/head
# node (offload heavy work to the queue) vs inside a PBS job, where CPU/RAM are
# already allocated and heavy work should run directly. Sets MQYOLO_ENV (login|
# pbs), MQYOLO_NCPUS, MQYOLO_MEM_GB. Runs on the host before the container, so it
# can read PBS_* and query qstat for the authoritative allocation.
_mqyolo_detect_resources() {
    MQYOLO_ENV="login"
    MQYOLO_NCPUS=""
    MQYOLO_MEM_GB=""
    [[ -n "${PBS_JOBID:-}" ]] || return 0
    MQYOLO_ENV="pbs"
    MQYOLO_NCPUS="${NCPUS:-}"
    if command -v qstat &>/dev/null; then
        local line
        while IFS= read -r line; do
            case "$line" in
                *Resource_List.ncpus\ =\ *) [[ -n "$MQYOLO_NCPUS" ]] || MQYOLO_NCPUS="${line##*= }" ;;
                *Resource_List.mem\ =\ *)   MQYOLO_MEM_GB="$(_mqyolo_mem_to_gb "${line##*= }")" ;;
            esac
        done < <(qstat -f "$PBS_JOBID" 2>/dev/null)
    fi
    [[ -n "$MQYOLO_NCPUS" ]] || MQYOLO_NCPUS="$(nproc 2>/dev/null || true)"
}

# Guidance injected into the AI tool's instructions (claude --append-system-prompt-file
# / codex ~/.codex/AGENTS.md) so it knows where heavy work should run. Single
# source of truth, also dumpable with `mqyolo --print-guidance`. Adapts to the
# detected environment.
_mqyolo_guidance_text() {
    _mqyolo_detect_resources
    if [[ "$MQYOLO_ENV" != "login" ]]; then
        local ncpus="${MQYOLO_NCPUS:-(unknown)}" membudget="" memphrase=""
        if [[ -n "$MQYOLO_MEM_GB" ]]; then
            memphrase=", ${MQYOLO_MEM_GB} GB RAM"
            membudget=" and memory under ${MQYOLO_MEM_GB} GB"
        fi
        printf '# Running commands on this HPC (mqyolo sandbox, inside a PBS job)\n\n'
        printf 'You are in an `mqyolo` sandbox running INSIDE a PBS job with %s CPUs%s\n' "$ncpus" "$memphrase"
        printf 'allocated. This is a finite budget — more than a shared login node, but\n'
        printf 'still limited.\n\n'
        printf -- '- Run work that FITS this allocation directly here, sized to it (e.g.\n'
        printf -- '  `--threads %s`%s).\n' "$ncpus" "$membudget"
        cat <<'GUIDE'
- For anything that needs MORE CPUs/RAM than this job has, or many jobs at once,
  submit it to the batch queue with `mqsub` instead of overloading this job — it
  runs on a separately-sized compute node:
      mqsub -t <cpus> -m <GB_RAM> --hours <H> -- <command>
  Such jobs run inside this same restricted sandbox (only the working directory,
  plus any paths granted to mqyolo at launch, is writable). Companions: `qstat`,
  `qdel`.

**Snakemake:** for a few rules that each fit this allocation, run
`snakemake --cores <N>` locally. For large or highly parallel workflows, prefer
`snakemake --profile aqua`, which submits each rule to the queue via `mqsub`
(separately sized) rather than squeezing everything into this one allocation.
GUIDE
        return 0
    fi

    cat <<'GUIDE'
# Running commands on this HPC (mqyolo sandbox)

You are in an `mqyolo` sandbox on the QUT *aqua* HPC, on a shared **login node**
inside a restricted container. A batch-queue submitter, `mqsub`, is available.

**Offload heavy work to the batch queue — do NOT run it directly here.**
Anything long-running, CPU-intensive, or memory-hungry (assemblies, alignments,
mapping, large downloads/compression, multi-minute scripts, anything wanting
many cores or more than a few GB of RAM) must be submitted with `mqsub`, not run
on the login node. Quick, cheap work (edits, builds, unit tests, short scripts,
inspecting files) can be run directly. (If instead you want abundant local
resources, start an interactive PBS job and run mqyolo inside it — the guidance
here adapts automatically.)

`mqsub` runs the real submitter on the host and, by default, waits for the job
and returns its output. Usage:

    mqsub --no-email -t <cpus> -m <GB_RAM> --hours <H> -- <command and args>
    mqsub --no-email --bg -t 8 -m 32 --days 2 -- <command>     # submit and return immediately

- `-t` cpus, `-m` GB RAM, `--hours/--days/--weeks` walltime. Size them to the job.
- Jobs run inside this SAME restricted sandbox on the compute node: only the
  working directory (plus any paths granted to mqyolo at launch) is writable;
  everything else is read-only. Write outputs under the current directory.
- Companions: `qstat` (queue status), `qdel` (cancel). Run `mqsub --help` for all options.
  (cancel). `qstat` also works. Run `mqsub --help` for all options.

**Snakemake:** `snakemake --profile aqua` submits each rule to the batch queue
via `mqsub` under the hood (one queue job per rule), so do not also wrap those
rules in `mqsub` yourself. This suits workflows with a modest number of larger
jobs. When instead there are MANY small/quick rules, one queue job each floods
the scheduler and is dominated by queue latency — in that case run snakemake
itself inside a single allocation and let it run rules locally within it, e.g.
`mqsub -t 24 -m 96 -- snakemake --cores 24` (no aqua profile). Pick per-rule
queue submission vs. one wrapping job based on the number and size of the rules.
GUIDE
}

# Parse tool name (default: claude), --debug, --rw-paths, --ro-paths, --no-broker
TOOL="claude"
DEBUG=0
NO_BROKER=0
RW_PATHS=()
RO_PATHS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        claude|codex|copilot) TOOL="$1"; shift ;;
        --debug)      DEBUG=1;   shift ;;
        --no-broker)  NO_BROKER=1; shift ;;
        --print-guidance) _mqyolo_guidance_text; exit 0 ;;
        --rw-paths)
            shift
            while [[ $# -gt 0 && "$1" != --* && "$1" != claude && "$1" != codex && "$1" != copilot ]]; do
                RW_PATHS+=("$1"); shift
            done
            ;;
        --ro-paths)
            shift
            while [[ $# -gt 0 && "$1" != --* && "$1" != claude && "$1" != codex && "$1" != copilot ]]; do
                RO_PATHS+=("$1"); shift
            done
            ;;
        help|-h|--help)
            cat <<'EOF'
mqyolo - run an AI coding tool inside a sandboxed Apptainer/Singularity container

USAGE
  mqyolo [claude|codex] [--debug] [--rw-paths PATH...] [--ro-paths PATH...] [--no-broker] [args...]

TOOLS
  claude   (default) Claude Code — passes --dangerously-skip-permissions
  codex              OpenAI Codex — bypasses Codex's own prompts/sandbox, enables search,
                     and disables update checks
  copilot            GitHub Copilot CLI — no auto-mode flag; use Shift+Tab inside session for Autopilot mode

OPTIONS
  --debug              Print the full exec command before running
  --rw-paths PATH...   Bind one or more extra paths into the container as read-write.
                       Jobs submitted via the broker inherit exactly these writable
                       paths; the AI inside the container cannot change them.
  --ro-paths PATH...   Bind one or more extra paths into the container as read-only.
                       Useful to re-expose a specific subdirectory of an otherwise
                       deny-listed tree (see FILESYSTEM below). Like --rw-paths,
                       jobs submitted via the broker inherit exactly these read-only
                       paths; the AI inside the container cannot change them.
  --no-broker          Do not start the mqsub broker (mqsub will be unavailable inside the container)
  --print-guidance     Print the mqsub guidance injected into the AI tool, then exit
  help, -h, --help     Show this help text

  Any remaining arguments are passed through verbatim to the tool.
  For example: mqyolo --resume <session-id>
               mqyolo codex --no-gitignore

LAUNCH DIRECTORY
  The working directory is bound read-write into the container, so mqyolo will
  only start from within one of these trees (to limit accidental data exposure):
    - /work/microbiome (or a subdirectory)
    - $HOME (or a subdirectory)
    - /scratch/microbiome/$USER (or a subdirectory)
    - /tmp (or a subdirectory)

CONTAINER
  Image:  $AI_TOOL_SIF, or <script-dir>/../singularity/ai_tool.sif by default
  Runtime: apptainer (preferred) or singularity

FILESYSTEM INSIDE THE CONTAINER
  Current directory   read-write  (so the AI can edit your code)
  /tmp, /var/tmp      read-write
  --rw-paths          read-write  (extra paths granted at launch)
  /home, /mnt, /pkg,
  /data, and other
  HPC mounts          read-only
  --ro-paths          read-only   (extra paths granted at launch)
  /etc                read-only   (DNS, SSL certs, nsswitch)
  /scratch            NOT visible — never bound, to limit data exfiltration.
                      Use --ro-paths/--rw-paths to opt a specific subdirectory
                      back in; it appears at the same /scratch/... path you gave
                      (even though /scratch is a symlink to /mnt/weka/scratch).
  /work/microbiome    NOT visible, EXCEPT /work/microbiome/sw and
                      /work/microbiome/db which are bound read-only (shared
                      tools and reference databases). Use --ro-paths to opt a
                      specific other subdirectory back in read-only.
  Everything else     not visible (--contain gives a clean slate)
  ~  (HOME)           isolated ephemeral directory, not your real home;
                      dotfiles are symlinked from your real home so tools
                      like git, ssh etc. pick up your config

MQSUB FROM INSIDE THE CONTAINER
  qsub and the python3.9 mqsub depends on do not exist inside the container, so
  mqsub cannot run there directly. Instead, mqyolo starts a lightweight broker
  on the host for the duration of the session (one broker per mqyolo session).
  Inside the container, mqsub/qstat/qdel are thin stubs that forward the request to the
  broker, which runs the real command on the host. mqsub jobs are
  automatically submitted with --sandbox, so each job runs on its compute node
  inside the SAME restricted container (only its working directory plus mqyolo's
  --rw-paths writable, and the same deny-list with mqyolo's --ro-paths re-exposed
  read-only) via mqsandbox. Those writable and read-only paths are fixed by mqyolo
  at launch and cannot be changed from inside the container. The broker exits when
  mqyolo exits or is killed; use --no-broker to disable it.

CLAUDE SETTINGS
  ~/.cache/           bound read-write so tools can read and write the
                      host cache directory (npm, pip, etc.)
  ~/.claude/          bound read-write so Claude Code can persist config,
                      history and keybindings across sessions
  ~/.claude.json      staged into the container home and written back on
                      exit; if another session modified it while mqyolo was
                      running a timestamped backup is saved to
                      ~/.claude/backups/

CODEX SETTINGS
  ~/.codex/           bound read-write so Codex config, auth and sessions
                      persist across mqyolo runs. When the broker is running,
                      mqyolo's generated guidance is mounted read-only over
                      ~/.codex/AGENTS.md inside the container.

ENVIRONMENT VARIABLES
  ANTHROPIC_API_KEY   Required for claude
  OPENAI_API_KEY      Required for codex
  GITHUB_TOKEN        Required for copilot
  OPENAI_BASE_URL     Optional — override OpenAI endpoint
  ANTHROPIC_BASE_URL  Optional — override Anthropic endpoint
  CLAUDE_CODE_USE_BEDROCK  Optional — use AWS Bedrock for Claude
  AI_TOOL_SIF         Override path to the container image
  TERM, COLORTERM, NO_COLOR  Passed through for correct terminal rendering

PATH INSIDE THE CONTAINER
  ~/bin and ~/.local/bin (if present) are prepended ahead of the container
  binaries so your personal scripts remain available. pixi_cmr_init.py (shipped
  with this repo) is also placed on PATH so the in-container AI can scaffold a
  pixi.toml.
EOF
            exit 0
            ;;
        *)            break ;;
    esac
done

# Auto-mount folders flagged "not sensitive" in the CMR work-folders sheet as
# read-only. They live under the otherwise-denied /work/microbiome tree, so they
# are added to RO_PATHS, which re-exposes them read-only inside the sandbox (and
# jobs submitted via the broker inherit them, just like explicit --ro-paths).
# Non-existent paths are skipped later by sandbox_build_binds, so listing folders
# that aren't present on this host is harmless.
while IFS= read -r _folder; do
    [[ -n "$_folder" ]] && RO_PATHS+=("$_folder")
done < <(_mqyolo_non_sensitive_folders "$NON_SENSITIVE_FOLDERS_FILE")
unset _folder

# Restrict where mqyolo may be launched (anti-leakage). The working directory is
# bound read-write into the sandbox; confining launches to these trees limits how
# much unrelated data can accidentally be exposed/made writable. Checked before
# the runtime/image checks so the message is clear regardless of build state.
CWD="$(realpath "$(pwd)")"
if ! _mqyolo_allowed_cwd "$CWD"; then
    {
        echo "Error: mqyolo must be launched from within one of:"
        echo "  - /work/microbiome (or a subdirectory)"
        echo "  - \$HOME (${HOME:-unset}) (or a subdirectory)"
        echo "  - /scratch/microbiome/${USER:-<username>} (or a subdirectory)"
        echo "  - /tmp (or a subdirectory)"
        echo "Current directory is: ${CWD}"
        echo "This restriction limits accidental read-write exposure of unrelated data inside the sandbox."
    } >&2
    exit 1
fi

# Runtime/image checks happen after arg parsing so that informational flags
# (--help, --print-guidance) work even without a built container image.
sandbox_detect_runtime
sandbox_require_sif "$SIF"

# ---------------------------------------------------------------------------
# Build the filesystem sandbox (shared with mqsandbox via _sandbox_common.bash)
# ---------------------------------------------------------------------------
BIND_ARGS=()
ENV_ARGS=()

# Ephemeral home directory (cleaned up on exit by the trap below).
sandbox_make_home

# --- Real ~/.claude settings (config, theme, history) — claude-specific ---
# HOME inside the container is /container_home. Bind ~/.claude/ and stage a copy
# of ~/.claude.json there so Claude Code can read/write its auth token and
# settings without touching the read-only home bind.
if [[ -d "${HOME}/.claude" ]]; then
    mkdir -p "${CONTAINER_HOME}/.claude"
    BIND_ARGS+=(--bind "${HOME}/.claude:/container_home/.claude:rw")
fi
if [[ -f "${HOME}/.claude.json" ]]; then
    cp "${HOME}/.claude.json" "${CONTAINER_HOME}/.claude.json"
    _CLAUDE_JSON_CKSUM="$(cksum "${HOME}/.claude.json" 2>/dev/null)"
fi

function _save_claude_json {
    local src="${CONTAINER_HOME}/.claude.json"  # temp staging copy
    local dst="${HOME}/.claude.json"
    if [[ -f "$src" ]]; then
        if [[ -f "$dst" ]] && ! cmp -s "$src" "$dst" && \
           [[ "${_CLAUDE_JSON_CKSUM:-}" != "$(cksum "$dst" 2>/dev/null)" ]]; then
            local backup="${HOME}/.claude/backups/.claude.json.backup.$(date +%s%3N)"
            mkdir -p "${HOME}/.claude/backups"
            cp -f "$dst" "$backup"
            echo "WARNING: ~/.claude.json was modified by another session. Saved backup: $backup" >&2
        fi
        cp -f "$src" "$dst"
    fi
}

# BROKER_PID is set below if the broker starts; the trap cleans up everything.
BROKER_PID=""
_cleaned_up=0
function _cleanup {
    [[ "$_cleaned_up" -eq 1 ]] && return
    _cleaned_up=1
    [[ -n "$BROKER_PID" ]] && kill "$BROKER_PID" 2>/dev/null
    _save_claude_json
    rm -rf "$CONTAINER_HOME"
}
# EXIT covers normal exit; INT/TERM/HUP cover signals. The broker also watches
# this script's PID, so even a kill -9 (which no trap can catch) cannot orphan it.
trap _cleanup EXIT
trap '_cleanup; exit 130' INT
trap '_cleanup; exit 143' TERM HUP

# Read-only/HPC/tmp/rw/CWD binds, then the ephemeral-home dotfiles. Extra
# read-only paths follow a `--` separator (see sandbox_build_binds).
sandbox_build_binds "$CWD" "${RW_PATHS[@]+"${RW_PATHS[@]}"}" -- "${RO_PATHS[@]+"${RO_PATHS[@]}"}"
sandbox_home_dotfiles

# ---------------------------------------------------------------------------
# mqsub broker (one per mqyolo session)
#
# Start a lightweight host-side broker that the container-side mqsub/mqstat/...
# stubs forward to. Its lifetime is tied to this session: the EXIT trap kills it,
# and it also self-terminates by watching this script's PID ($$), so even a
# `kill -9` of mqyolo does not orphan it. The spool and shim dirs live inside
# CONTAINER_HOME, so they are bound into the container for free and removed on
# exit with the rest of the ephemeral home.
# ---------------------------------------------------------------------------
SANDBOX_PATH_PREFIX=""
MQYOLO_GUIDANCE_FILE=""   # in-container path to the mqsub guidance, set when broker is on

# Extra directories to prepend to PATH inside the container, highest priority
# first. Applied via SANDBOX_PATH_PREFIX (sandbox_build_env) AND re-prepended by
# the shim ~/.bashrc below, so they keep winning even after the user's ~/.bashrc is
# (re-)sourced. Paths are the in-container view (CONTAINER_HOME -> /container_home).
_PATH_PREFIX_DIRS=()

# --- Repo tools on PATH inside the container (see sandbox_stage_repo_tools) ---
TOOLS_DIR="${CONTAINER_HOME}/.mqyolo/tools"
sandbox_stage_repo_tools "$TOOLS_DIR" "$SCRIPT_DIR"
_PATH_PREFIX_DIRS+=("/container_home/.mqyolo/tools")

if [[ "$NO_BROKER" -eq 0 && -x "${SCRIPT_DIR}/mqsub-broker" && -x "${SCRIPT_DIR}/mqbroker-stub" ]]; then
    BROKER_SPOOL="${CONTAINER_HOME}/.mqyolo/broker"
    SHIM_DIR="${CONTAINER_HOME}/.mqyolo/shims"
    mkdir -p "$BROKER_SPOOL" "$SHIM_DIR"

    # Symlink the stub as each proxied command. The target must be valid INSIDE
    # the container, so use the canonical path (bound ro under /home|/mnt|/work).
    # qstat/qdel are proxied too so `snakemake --profile aqua` works in the
    # container: its cluster-status helper (snakemake_mqstat) calls `qstat` and its
    # cluster-cancel command is `qdel`, neither of which exists inside the sandbox.
    _stub_real="$(readlink -f "${SCRIPT_DIR}/mqbroker-stub")"
    for _c in mqsub mqstat mqwait mqdel qstat qdel; do
        ln -sf "$_stub_real" "${SHIM_DIR}/${_c}"
    done
    unset _c _stub_real

    # Pass this session's --rw-paths/--ro-paths to the broker as the FIXED sets of
    # writable and read-only paths for every submitted job. The broker forces these
    # and rejects any attempt to set them from inside the container, so the AI can
    # neither widen what its jobs may write to nor re-expose anything beyond what
    # you granted mqyolo at launch.
    # Pass the literal absolute paths (symlinks preserved, e.g. /scratch/... rather
    # than the resolved /mnt/weka/scratch/...) so a job's sandbox sees them at the
    # same place this session does; sandbox_build_binds resolves the real source and
    # also binds the literal path, so the /scratch symlink (absent in the container)
    # is not required.
    _broker_rw=()
    for _p in "${RW_PATHS[@]+"${RW_PATHS[@]}"}"; do
        _broker_rw+=(--rw-path "$(realpath -s "$_p" 2>/dev/null || echo "$_p")")
    done
    _broker_ro=()
    for _p in "${RO_PATHS[@]+"${RO_PATHS[@]}"}"; do
        _broker_ro+=(--ro-path "$(realpath -s "$_p" 2>/dev/null || echo "$_p")")
    done
    _broker_dbg=()
    [[ "$DEBUG" -eq 1 ]] && _broker_dbg=(--debug)
    "${SCRIPT_DIR}/mqsub-broker" --spool "$BROKER_SPOOL" --watch-pid "$$" \
        "${_broker_rw[@]}" "${_broker_ro[@]}" "${_broker_dbg[@]}" &
    BROKER_PID=$!
    unset _broker_dbg _broker_rw _broker_ro _p

    # The shim dir lives at this path inside the container too (CONTAINER_HOME ->
    # /container_home). It must beat everything (including the repo tools dir) so the
    # container-side mqsub stub shadows the real mqsub; prepend it ahead of the rest.
    _PATH_PREFIX_DIRS=("/container_home/.mqyolo/shims" "${_PATH_PREFIX_DIRS[@]}")
    # Tell the stubs where to drop requests (in-container path).
    ENV_ARGS+=(--env "MQBROKER_SPOOL=/container_home/.mqyolo/broker")

    # Guidance injected into the AI tool's instructions so it knows to offload
    # heavy work to the batch queue via mqsub instead of running it on the login
    # node. Delivered to claude via --append-system-prompt-file and to codex via
    # its global ~/.codex/AGENTS.md (see the tool case below). Same text as
    # `mqyolo --print-guidance`.
    _mqyolo_guidance_text > "${CONTAINER_HOME}/.mqyolo/guidance.md"
    MQYOLO_GUIDANCE_FILE="/container_home/.mqyolo/guidance.md"
fi

# Join the prefix dirs and expose them on PATH (sandbox_build_env prepends
# SANDBOX_PATH_PREFIX to CONTAINER_PATH). Setting PATH up front is not enough: the
# user's ~/.bashrc (sourced at shell startup, and re-sourced by Claude Code's shell
# snapshot) prepends the real hpc_scripts bin dir, shadowing these. Give the
# container its OWN ~/.bashrc that sources the real one and THEN re-prepends our
# dirs, so they keep winning no matter how often .bashrc is sourced.
# (.bash_profile/.profile both end by sourcing ~/.bashrc, covering login shells.)
SANDBOX_PATH_PREFIX="$(IFS=:; printf '%s' "${_PATH_PREFIX_DIRS[*]}")"
_real_bashrc="$(readlink -f "${HOME}/.bashrc" 2>/dev/null || true)"
sandbox_write_shim_bashrc "${CONTAINER_HOME}/.bashrc" "$_real_bashrc" "$SANDBOX_PATH_PREFIX"
unset _real_bashrc

# ---------------------------------------------------------------------------
# Environment variables (PATH honours SANDBOX_PATH_PREFIX set above)
# ---------------------------------------------------------------------------
sandbox_build_env ANTHROPIC_API_KEY OPENAI_API_KEY GITHUB_TOKEN \
                  OPENAI_BASE_URL ANTHROPIC_BASE_URL CLAUDE_CODE_USE_BEDROCK \
                  PIXI_CACHE_DIR RATTLER_CACHE_DIR \
                  TERM COLORTERM NO_COLOR

# ---------------------------------------------------------------------------
# Tool-specific flags
# ---------------------------------------------------------------------------
case "$TOOL" in
    claude)
        # Skip all permission prompts — the container is the sandbox
        YOLO_ARGS=("--dangerously-skip-permissions")
        # Tell Claude to offload heavy commands to mqsub.
        [[ -n "$MQYOLO_GUIDANCE_FILE" ]] && \
            YOLO_ARGS+=("--append-system-prompt-file" "$MQYOLO_GUIDANCE_FILE")
        ;;
    codex)
        # Run without Codex's own prompts/sandbox inside the mqyolo container,
        # enable Codex web search, and suppress self-update prompts because the
        # SIF rebuild handles updates.
        YOLO_ARGS=(
            "--dangerously-bypass-approvals-and-sandbox"
            "--search"
            "-c" "check_for_update_on_startup=false"
        )
        # Codex reads global instructions from $CODEX_HOME/AGENTS.md (~/.codex).
        # Bind the real ~/.codex read-write so config, auth and sessions persist.
        # The mqyolo guidance is exposed as AGENTS.md via a file bind, so we do
        # not overwrite the user's real ~/.codex/AGENTS.md.
        mkdir -p "${HOME}/.codex"
        _codex_real="$(readlink -f "${HOME}/.codex" 2>/dev/null || echo "${HOME}/.codex")"
        rm -rf "${CONTAINER_HOME}/.codex"
        sandbox_bind_codex_home "$_codex_real" "/container_home/.codex" \
            "${CONTAINER_HOME}/.mqyolo/guidance.md"
        unset _codex_real
        ;;
    copilot)
        # No CLI flag for auto mode; use Shift+Tab inside the session for Autopilot mode
        # (Copilot CLI has no global-instructions hook we can inject mqsub guidance into.)
        YOLO_ARGS=()
        ;;
esac

# ---------------------------------------------------------------------------
# Run (as a child, not exec, so the EXIT trap fires: broker teardown,
# .claude.json save-back, and ephemeral-home cleanup all depend on it)
# ---------------------------------------------------------------------------
if [[ "$DEBUG" -eq 1 ]]; then
    echo "mqyolo: exec command:" >&2
    printf '  %q' "$RUNTIME" exec --contain \
        "${BIND_ARGS[@]}" "${ENV_ARGS[@]}" \
        --pwd "${CWD}" "${SIF}" \
        bash -c '[[ -f ~/.bashrc ]] && source ~/.bashrc 2>/dev/null; exec "$@"' _ \
        "${TOOL}" "${YOLO_ARGS[@]}" "$@" >&2
    echo >&2
fi

"$RUNTIME" exec \
    --contain \
    "${BIND_ARGS[@]}" \
    "${ENV_ARGS[@]}" \
    --pwd "${CWD}" \
    "${SIF}" \
    bash -c '[[ -f ~/.bashrc ]] && source ~/.bashrc 2>/dev/null; exec "$@"' _ \
    "${TOOL}" "${YOLO_ARGS[@]}" "$@"
exit $?
