Bootstrap: docker
From: node:24

%labels
    Description Claude Code / OpenAI Codex CLI / GitHub Copilot CLI in a restricted container

%post
    # Handful of CLI tools missing from the base image.
    #   time:  /usr/bin/time, expected by benchmarking wrappers (e.g. mqsub) and
    #          many build/test scripts; without it they fail with
    #          "/usr/bin/time: No such file or directory".
    #   less:  default pager many tools (git, etc.) shell out to.
    #   rsync: commonly invoked for file transfers inside sessions.
    #   curl:  needed for Codex CLI installation script.
    #   gawk:  needed for Codex CLI installation script.
    #   man-db: provides the `man` command for reading manual pages.
    apt-get update
    apt-get install -y --no-install-recommends time less rsync curl ca-certificates gawk jq man-db
    rm -rf /var/lib/apt/lists/*

    # Install Claude Code, OpenAI Codex CLI, and GitHub Copilot CLI
    npm install -g @anthropic-ai/claude-code@latest @github/copilot@latest

    # Codex doesn't install the newest via npm, try the recommended way
    curl -fsSL https://chatgpt.com/codex/install.sh | CODEX_NON_INTERACTIVE=1 sh

    # Isolated home directory for the container (never touches real $HOME)
    mkdir -p /container_home
    chmod 777 /container_home

%environment
    export HOME=/container_home
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%runscript
    exec "$@"
